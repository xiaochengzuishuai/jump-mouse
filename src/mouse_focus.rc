#pragma code_page(65001)

#include <Windows.h>
#include "resource.h"

CREATEPROCESS_MANIFEST_RESOURCE_ID RT_MANIFEST "dpi_aware.manifest"
IDI_APP_ICON ICON "../ico图标/1.ico"

#define UDS_SETBUDDYINT 0x0002
#define UDS_AUTOBUDDY   0x0010
#define UDS_ALIGNRIGHT  0x0004
#define UDS_ARROWKEYS   0x0020

IDD_MAIN_DIALOG DIALOGEX 0, 0, 430, 550
STYLE DS_SETFONT | DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
EXSTYLE WS_EX_CONTROLPARENT
CAPTION "Mouse Focus — 设置"
FONT 9, "Segoe UI"
{
    // ===== 核心行为 =====
    GROUPBOX        "核心行为", IDC_STATIC, 10, 8, 410, 110

    CONTROL         "仅 Alt+Tab 切换", IDC_RADIO_ALT_TAB, "Button",
                    BS_AUTORADIOBUTTON | WS_GROUP | WS_TABSTOP,
                    22, 24, 130, 14
    CONTROL         "任意窗口聚焦变化", IDC_RADIO_ANY, "Button",
                    BS_AUTORADIOBUTTON | WS_TABSTOP,
                    170, 24, 150, 14

    CONTROL         "瞬间移动", IDC_RADIO_INSTANT, "Button",
                    BS_AUTORADIOBUTTON | WS_GROUP | WS_TABSTOP,
                    22, 44, 80, 14
    CONTROL         "平滑动画", IDC_RADIO_SMOOTH, "Button",
                    BS_AUTORADIOBUTTON | WS_TABSTOP,
                    110, 44, 80, 14

    LTEXT           "时长:", IDC_STATIC, 200, 46, 30, 12
    EDITTEXT        IDC_EDIT_DURATION, 230, 44, 40, 14, ES_NUMBER | WS_TABSTOP
    CONTROL         "", IDC_SPIN_DURATION, "msctls_updown32",
                    UDS_SETBUDDYINT | UDS_AUTOBUDDY | UDS_ALIGNRIGHT | UDS_ARROWKEYS,
                    0, 0, 0, 0

    LTEXT           "延迟:", IDC_STATIC, 280, 46, 30, 12
    EDITTEXT        IDC_EDIT_DELAY, 310, 44, 40, 14, ES_NUMBER | WS_TABSTOP
    CONTROL         "", IDC_SPIN_DELAY, "msctls_updown32",
                    UDS_SETBUDDYINT | UDS_AUTOBUDDY | UDS_ALIGNRIGHT | UDS_ARROWKEYS,
                    0, 0, 0, 0

    CONTROL         "窗口中心（含标题栏）", IDC_RADIO_WINDOW, "Button",
                    BS_AUTORADIOBUTTON | WS_GROUP | WS_TABSTOP,
                    22, 66, 160, 14
    CONTROL         "客户区中心", IDC_RADIO_CLIENT, "Button",
                    BS_AUTORADIOBUTTON | WS_TABSTOP,
                    190, 66, 80, 14

    CONTROL         "启用服务", IDC_CHECK_ENABLED, "Button",
                    BS_AUTOCHECKBOX | WS_TABSTOP,
                    22, 88, 80, 14

    // ===== 移动后临时变更 =====
    GROUPBOX        "移动后临时变更", IDC_STATIC, 10, 126, 410, 152

    CONTROL         "启用", IDC_CHECK_HIGHLIGHT, "Button",
                    BS_AUTOCHECKBOX | WS_TABSTOP,
                    22, 142, 45, 14

    LTEXT           "当前光标", IDC_STATIC, 22, 162, 72, 12
    CONTROL         "", IDC_CANVAS_CURRENT, "Static",
                    SS_OWNERDRAW | SS_NOTIFY | WS_BORDER,
                    22, 176, 72, 72

    LTEXT           "临时变更预览", IDC_STATIC, 110, 162, 100, 12
    CONTROL         "", IDC_CANVAS_PREVIEW, "Static",
                    SS_OWNERDRAW | SS_NOTIFY | WS_BORDER,
                    110, 176, 72, 72

    LTEXT           "形状:", IDC_STATIC, 200, 170, 30, 12
    COMBOBOX        IDC_COMBO_SHAPE, 230, 168, 80, 120,
                    CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP

    LTEXT           "颜色:", IDC_STATIC, 200, 192, 30, 12
    COMBOBOX        IDC_COMBO_COLOR, 230, 190, 80, 100,
                    CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP

    LTEXT           "大小:", IDC_STATIC, 320, 170, 30, 12
    EDITTEXT        IDC_EDIT_HIGHLIGHT_SIZE, 348, 168, 36, 14, ES_NUMBER | WS_TABSTOP
    CONTROL         "", IDC_SPIN_HIGHLIGHT_SIZE, "msctls_updown32",
                    UDS_SETBUDDYINT | UDS_AUTOBUDDY | UDS_ALIGNRIGHT | UDS_ARROWKEYS,
                    0, 0, 0, 0

    PUSHBUTTON      "浏览自定义光标...", IDC_BTN_BROWSE_CUR, 200, 215, 120, 15

    LTEXT           "恢复条件：检测到鼠标移动后自动恢复原始光标", IDC_STATIC,
                    22, 250, 300, 12

    // ===== 排除规则 =====
    GROUPBOX        "排除规则", IDC_STATIC, 10, 286, 410, 90

    LTEXT           "进程名列表（如 devenv.exe）：", IDC_STATIC, 22, 302, 200, 12
    LISTBOX         IDC_LIST_EXCLUDE, 22, 316, 280, 44,
                    LBS_NOTIFY | WS_VSCROLL | WS_BORDER | WS_TABSTOP
    PUSHBUTTON      "添加", IDC_BTN_ADD, 310, 316, 50, 15
    PUSHBUTTON      "移除", IDC_BTN_REMOVE, 310, 336, 50, 15

    // ===== 守护进程 =====
    GROUPBOX        "守护进程状态", IDC_STATIC, 10, 384, 410, 50

    LTEXT           "状态:", IDC_STATIC, 22, 404, 30, 12
    LTEXT           "未知", IDC_STATUS, 55, 404, 100, 12
    PUSHBUTTON      "启动", IDC_BTN_START, 180, 400, 50, 15
    PUSHBUTTON      "停止", IDC_BTN_STOP, 238, 400, 50, 15
    CONTROL         "开机自启", IDC_CHECK_AUTOSTART, "Button",
                    BS_AUTOCHECKBOX | WS_TABSTOP,
                    310, 402, 80, 14

    GROUPBOX        "日志", IDC_STATIC, 10, 442, 410, 42

    LTEXT           "日志级别:", IDC_STATIC, 22, 460, 50, 12
    COMBOBOX        IDC_COMBO_LOG, 72, 458, 80, 80,
                    CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP

    DEFPUSHBUTTON   "保存设置", IDOK, 200, 510, 70, 22
    PUSHBUTTON      "关闭", IDCANCEL, 280, 510, 70, 22
}

IDD_INPUT_DIALOG DIALOGEX 0, 0, 280, 70
STYLE DS_SETFONT | DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "添加排除进程"
FONT 9, "Segoe UI"
{
    LTEXT           "请输入进程名（如 devenv.exe）：", IDC_STATIC, 12, 10, 250, 12
    EDITTEXT        IDC_INPUT_TEXT, 12, 24, 256, 14, ES_AUTOHSCROLL | WS_TABSTOP
    DEFPUSHBUTTON   "确定", IDOK, 120, 46, 60, 15
    PUSHBUTTON      "取消", IDCANCEL, 190, 46, 60, 15
}
